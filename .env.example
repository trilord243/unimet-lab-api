# WhatsApp Business API (Meta Graph)
WHATSAPP_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_BUSINESS_PHONE=xxxxxxxxxxxxxx
WHATSAPP_API_VERSION=v22.0

# Notificaciones admin (recibe alertas de nuevas reservas/solicitudes)
ADMIN_NOTIFICATION_EMAIL=profesor@unimet.edu.ve
ADMIN_NOTIFICATION_WHATSAPP=58412xxxxxxx
